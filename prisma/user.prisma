model User {
    id Int @id @default(autoincrement())
    first_name String
    last_name String
    age Int?
    isVerified Boolean @default(false)
    email String @unique
    password String
    createdAt DateTime @default(now())

    profile Profile?
}



model Verification {
    id        Int      @id @default(autoincrement())
    code      String   @unique
    user_id   Int      @unique
    password  String
    createdAt DateTime @default(now())
}

model Profile {
    id Int @id @default(autoincrement())
    profile_pics String?
    phone_number String?
    userId Int @unique
    user User @relation(fields: [userId], references: [id] )
}